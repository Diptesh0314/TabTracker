{
  "name": "Tabs Tracker",
  "description": "Tracks Tab activities",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "tracker.html"
  },
  "background": {
    "service_worker": "background/worker.js"
  },
  "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content/injector.js"]
        }
    ],
  "permissions":[
    "tabs"
  ]
}